# ── ZombieCoder MCP — Environment Configuration Template ──
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Active provider (default: GROQBRIDGE)
ACTIVE_PROVIDER=GROQBRIDGE

# Agent defaults
AGENT_MODEL=auto
AGENT_MAX_STEPS=10
AGENT_TEMPERATURE=0

# ── Provider Configuration ──
# Uncomment and configure each provider you want to use.
# Format: PROVIDER_{ID}_URL=...
#         PROVIDER_{ID}_KEY=...
#         PROVIDER_{ID}_NAME=... (optional)

# Groq Bridge Proxy
PROVIDER_GROQBRIDGE_URL=https://your-proxy.example.com/v1
PROVIDER_GROQBRIDGE_KEY=your-key-here
PROVIDER_GROQBRIDGE_NAME=Groq Bridge Proxy

# OpenCode Zen
# PROVIDER_OPENCODE_URL=https://opencode.ai/zen/v1
# PROVIDER_OPENCODE_KEY=sk-...

# Google Gemini (OpenAI-compatible endpoint)
# PROVIDER_GOOGLE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# PROVIDER_GOOGLE_KEY=AIza...

# Ollama (local)
# PROVIDER_OLLAMA_URL=http://localhost:11434/v1
# PROVIDER_OLLAMA_KEY=ollama

# Groq Direct
# PROVIDER_GROQ_URL=https://api.groq.com/openai/v1
# PROVIDER_GROQ_KEY=gsk_...

# Local Server
# PROVIDER_LOCAL_URL=http://localhost:8080/v1
# PROVIDER_LOCAL_KEY=proxy-no-auth

# ── Server ──
MCP_SERVER_PORT=5500
MCP_SERVER_HOST=localhost

# ── Persistence ──
DB_PATH=./zombiecoder.db
LOG_DIR=./logs
